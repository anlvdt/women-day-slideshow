rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Collection photos — ảnh team nữ (admin upload)
    match /photos/{photoId} {
      allow read: if true;
      allow create, delete: if true;
      allow update: if true;
    }

    // Collection wishes — lời chúc CHUNG từ team nam
    match /wishes/{wishId} {
      allow read: if true;
      allow create: if request.resource.data.senderName is string
                    && request.resource.data.senderName.size() >= 2
                    && request.resource.data.senderName.size() <= 50
                    && request.resource.data.message is string
                    && request.resource.data.message.size() >= 2
                    && request.resource.data.message.size() <= 5000;
      allow delete: if true;
      allow update: if false;
    }

    // Collection config - cài đặt nhạc nền / slideshow
    match /config/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
